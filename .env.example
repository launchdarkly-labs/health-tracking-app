# Copy this file to `.env` and paste your LaunchDarkly client-side ID below.
#
# Where to find it:
#   LaunchDarkly dashboard -> Account settings -> Projects
#   -> pick your project -> Environments tab
#   -> copy the "Client-side ID" value (NOT the SDK key)
#
# The client-side ID is safe to ship in client-side code.
# The SDK key is a secret and must NOT be used here.
VITE_LAUNCHDARKLY_CLIENT_ID=
